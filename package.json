{
  "name": "interview-review-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "node --env-file-if-exists=.env.local ./scripts/db-init.mjs db/schema.sql",
    "db:seed": "node --env-file-if-exists=.env.local ./scripts/db-init.mjs db/seed.sql",
    "db:init": "node --env-file-if-exists=.env.local ./scripts/db-init.mjs",
    "test:e2e": "playwright test",
    "test:integration": "node ./scripts/run-integration-tests.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "next": "16.2.2",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
